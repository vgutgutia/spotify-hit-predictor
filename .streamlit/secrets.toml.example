# Copy this file to .streamlit/secrets.toml (which is gitignored) and fill in
# your Spotify Developer credentials. Get them from
# https://developer.spotify.com/dashboard → Create an App → Settings.
#
# For Hugging Face Spaces deployment, set the same two keys via the Space's
# Settings → Repository secrets UI instead of committing this file.

SPOTIFY_CLIENT_ID = "your-client-id-here"
SPOTIFY_CLIENT_SECRET = "your-client-secret-here"
